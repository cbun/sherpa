{
  "name": "@sherpa/sdk",
  "version": "0.1.0",
  "description": "Node/Bun SDK for Sherpa procedural memory",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbun/sherpa.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/cbun/sherpa/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/cbun/sherpa/issues"
  },
  "keywords": [
    "workflow-memory",
    "procedural-memory",
    "sdk",
    "openclaw"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sherpa/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
