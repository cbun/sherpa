{
  "id": "sherpa",
  "name": "Sherpa",
  "description": "Procedural workflow memory for OpenClaw",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "transport": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["embedded", "stdio", "http"],
            "default": "embedded"
          },
          "command": {
            "type": "string",
            "default": "sherpa"
          },
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "baseUrl": {
            "type": "string",
            "default": "http://127.0.0.1:8787"
          },
          "manageProcess": {
            "type": "boolean",
            "default": false
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1,
            "default": 3000
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "default": {}
          }
        }
      },
      "store": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "root": {
            "type": "string",
            "default": "~/.openclaw/agents/{agentId}/sherpa"
          }
        }
      },
      "ledger": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "redactRawText": { "type": "boolean", "default": true },
          "maxMetaBytes": { "type": "integer", "minimum": 64, "default": 2048 }
        }
      },
      "order": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "default": { "type": "integer", "minimum": 1, "default": 3 },
          "min": { "type": "integer", "minimum": 1, "default": 1 },
          "max": { "type": "integer", "minimum": 1, "default": 5 },
          "backoff": { "type": "boolean", "default": true },
          "minSupport": { "type": "integer", "minimum": 1, "default": 1 }
        }
      },
      "advisory": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "injectThreshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.75 },
          "maxCandidates": { "type": "integer", "minimum": 1, "default": 3 },
          "maxRisks": { "type": "integer", "minimum": 1, "default": 2 },
          "maxChars": { "type": "integer", "minimum": 1, "default": 900 }
        }
      },
      "taxonomy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rules": {
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "match": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "type": "string", "enum": ["message", "session", "task", "tool"] },
                    "source": { "type": "string" },
                    "type": { "type": "string" },
                    "actor": { "type": "string" },
                    "toolName": { "type": "string" },
                    "toolFamily": { "type": "string", "enum": ["tool", "browser", "web", "automation"] },
                    "phase": { "type": "string", "enum": ["started", "succeeded", "failed"] },
                    "channel": { "type": "string" },
                    "contentPattern": { "type": "string" }
                  }
                },
                "set": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "type": { "type": "string" },
                    "outcome": { "type": "string", "enum": ["success", "failure", "unknown"] },
                    "labels": {
                      "type": "array",
                      "items": { "type": "string" },
                      "default": []
                    }
                  }
                }
              }
            }
          }
        }
      },
      "update": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "onBoot": { "type": "boolean", "default": true },
          "interval": { "type": "string", "default": "5m" },
          "debounceMs": { "type": "integer", "minimum": 0, "default": 10000 },
          "commandTimeoutMs": { "type": "integer", "minimum": 1, "default": 3000 },
          "rebuildOnVersionChange": { "type": "boolean", "default": false }
        }
      },
      "scope": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "default": { "type": "string", "enum": ["allow", "deny"], "default": "deny" },
          "rules": {
            "type": "array",
            "default": [
              { "action": "allow", "match": { "chatType": "direct" } }
            ],
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "action": { "type": "string", "enum": ["allow", "deny"] },
                "match": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "chatType": { "type": "string", "enum": ["direct", "group", "channel", "dm"] },
                    "channel": { "type": "string" },
                    "sessionPrefix": { "type": "string" },
                    "rawSessionPrefix": { "type": "string" },
                    "agentId": { "type": "string" }
                  }
                }
              },
              "required": ["action"]
            }
          }
        }
      },
      "ignoreSessionPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["agent:*:cron:**"]
      },
      "statelessSessionPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": []
      },
      "caseSplitting": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "markers": {
            "type": "array",
            "items": { "type": "string" },
            "default": ["/new", "/task", "task:", "case:"]
          },
          "completeMarkers": {
            "type": "array",
            "items": { "type": "string" },
            "default": ["/done", "/complete", "done:", "complete:"]
          },
          "failMarkers": {
            "type": "array",
            "items": { "type": "string" },
            "default": ["/fail", "/failed", "failed:", "blocked:"]
          },
          "auto": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "idleTimeout": { "type": "string", "default": "30m" },
              "staleTimeout": { "type": "string", "default": "2h" },
              "minContentChars": { "type": "integer", "minimum": 1, "default": 24 },
              "shiftPhrases": {
                "type": "array",
                "items": { "type": "string" },
                "default": [
                  "switching gears",
                  "separate task",
                  "separately",
                  "another task",
                  "another request",
                  "different issue",
                  "different question",
                  "new issue",
                  "new topic",
                  "one more thing",
                  "unrelated"
                ]
              },
              "maxTitleTokenOverlap": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.25 },
              "acknowledgmentPhrases": {
                "type": "array",
                "items": { "type": "string" },
                "default": ["thanks", "thank you", "got it", "sounds good", "ok", "okay", "perfect"]
              },
              "completePhrases": {
                "type": "array",
                "items": { "type": "string" },
                "default": [
                  "that solved it",
                  "that worked",
                  "issue resolved",
                  "problem solved",
                  "we are good",
                  "we're good",
                  "fixed now"
                ]
              },
              "failPhrases": {
                "type": "array",
                "items": { "type": "string" },
                "default": [
                  "still blocked",
                  "this failed",
                  "that failed",
                  "did not work",
                  "didn't work",
                  "cannot proceed",
                  "can't proceed"
                ]
              }
            }
          }
        }
      },
      "capture": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "messages": { "type": "boolean", "default": true },
          "tools": { "type": "boolean", "default": true },
          "browser": { "type": "boolean", "default": true },
          "web": { "type": "boolean", "default": true },
          "automation": { "type": "boolean", "default": true },
          "memoryWrites": { "type": "boolean", "default": false }
        }
      }
    }
  },
  "uiHints": {
    "transport.mode": {
      "label": "Transport Mode"
    },
    "transport.command": {
      "label": "Transport Command"
    },
    "transport.args": {
      "label": "Transport Args"
    },
    "transport.baseUrl": {
      "label": "Transport Base URL"
    },
    "transport.manageProcess": {
      "label": "Manage Transport Process"
    },
    "transport.timeoutMs": {
      "label": "Transport Timeout"
    },
    "store.root": {
      "label": "Store Root",
      "placeholder": "~/.openclaw/agents/{agentId}/sherpa"
    },
    "ledger.redactRawText": {
      "label": "Redact Raw Text"
    },
    "ledger.maxMetaBytes": {
      "label": "Max Meta Bytes"
    },
    "order.default": {
      "label": "Default Order"
    },
    "order.min": {
      "label": "Minimum Order"
    },
    "order.max": {
      "label": "Maximum Order"
    },
    "order.minSupport": {
      "label": "Minimum Support"
    },
    "advisory.enabled": {
      "label": "Enable Advisories"
    },
    "taxonomy.rules": {
      "label": "Taxonomy Rules"
    },
    "advisory.injectThreshold": {
      "label": "Advisory Threshold"
    },
    "update.onBoot": {
      "label": "Initialize On Boot"
    },
    "update.interval": {
      "label": "Maintenance Interval"
    },
    "update.debounceMs": {
      "label": "Capture Debounce"
    },
    "scope.default": {
      "label": "Scope Default"
    },
    "scope.rules": {
      "label": "Scope Rules"
    },
    "ignoreSessionPatterns": {
      "label": "Ignore Sessions"
    },
    "statelessSessionPatterns": {
      "label": "Stateless Sessions"
    },
    "caseSplitting.enabled": {
      "label": "Enable Case Splitting"
    },
    "caseSplitting.markers": {
      "label": "Case Split Markers"
    },
    "caseSplitting.completeMarkers": {
      "label": "Case Complete Markers"
    },
    "caseSplitting.failMarkers": {
      "label": "Case Fail Markers"
    },
    "caseSplitting.auto.enabled": {
      "label": "Auto Split Cases"
    },
    "caseSplitting.auto.idleTimeout": {
      "label": "Auto Split Idle Timeout"
    },
    "caseSplitting.auto.staleTimeout": {
      "label": "Auto Split Stale Timeout"
    },
    "caseSplitting.auto.minContentChars": {
      "label": "Auto Split Min Chars"
    },
    "caseSplitting.auto.shiftPhrases": {
      "label": "Auto Split Shift Phrases"
    },
    "caseSplitting.auto.maxTitleTokenOverlap": {
      "label": "Auto Split Max Token Overlap"
    },
    "capture.messages": {
      "label": "Capture Messages"
    },
    "capture.tools": {
      "label": "Capture Tools"
    },
    "capture.browser": {
      "label": "Capture Browser"
    },
    "capture.web": {
      "label": "Capture Web"
    },
    "capture.automation": {
      "label": "Capture Automation"
    }
  }
}
