{
  "name": "@sherpa/openclaw",
  "version": "0.1.0",
  "description": "OpenClaw plugin for Sherpa procedural memory",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbun/sherpa.git",
    "directory": "packages/openclaw"
  },
  "homepage": "https://github.com/cbun/sherpa/tree/main/packages/openclaw#readme",
  "bugs": {
    "url": "https://github.com/cbun/sherpa/issues"
  },
  "keywords": [
    "workflow-memory",
    "procedural-memory",
    "openclaw",
    "plugin"
  ],
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.28",
      "pluginSdkVersion": "2026.3.28"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sherpa/core": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "openclaw": "^2026.3.28",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
