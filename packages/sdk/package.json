{
  "name": "@sherpa/sdk",
  "version": "0.1.0",
  "description": "Node/Bun SDK for Sherpa procedural memory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sherpa/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
