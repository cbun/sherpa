{
  "name": "@sherpa/mcp",
  "version": "0.1.0",
  "description": "MCP stdio server for Sherpa procedural memory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sherpa-mcp": "./dist/index.js",
    "sherpa-mcp-http": "./dist/http.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sherpa/sdk": "workspace:*",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
